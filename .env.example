# Copy to .env and fill in values

# Anthropic API key - required for LLM agent scorer
ANTHROPIC_API_KEY=

# Reverb API key — required when MARKETPLACE=reverb
# Obtain from https://reverb.com/my/api_settings
REVERB_API_KEY=

# Marketplace backend: "reverb" (live) or "fixture" (offline, default)
MARKETPLACE=reverb

# Set to "debug" to log LLM prompts and responses to the scan log file
# LOG_LEVEL=debug

# Set to "stub" to skip LLM calls during local development/testing
# LLM_MODE=stub
